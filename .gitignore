# --- Python (Basura temporal) ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Binarios y Ejecutables (IMPORTANTE) ---
# Esto evita que FFmpeg u otros .exe se suban a GitHub
*.exe
*.dll
*.so

# --- Archivos de Salida de tus Scripts ---
# Ignoramos los resultados (videos, música, pdfs) para que no pesen en la nube
*.mp4
*.mkv
*.webm
*.mp3
*.pdf
*.docx
*.png
*.jpg
*.jpeg

# --- Excepción: Si quieres guardar iconos o imágenes de diseño ---
# Crea una carpeta llamada 'assets' y mete ahí los logos; Git SI los verá
!assets/*.png
!assets/*.jpg

# --- Basura de Sistema y Logs ---
Thumbs.db
desktop.ini
*.log
error_log.txt
.vscode/
.idea/